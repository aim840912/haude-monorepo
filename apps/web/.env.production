# ==============================================================================
# Haude V2 Web (Next.js) - Production Environment Variables
# ==============================================================================
# 此檔案定義 production 建置的預設值
# Vercel/CI 環境變數會覆蓋此處的設定
# ==============================================================================

# Backend API (Render)
NEXT_PUBLIC_API_BASE_URL=https://haude-api.onrender.com

# Mock 模式：production 必須為 false
NEXT_PUBLIC_USE_MOCK=false
