# ==============================================================================
# Haude V2 Web (Next.js) - Environment Variables
# ==============================================================================
# 複製此檔案為 .env.local 並填入實際值
# cp .env.example .env.local
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------
# 只設定 Base URL（不含版本），版本在 api.ts 中集中管理
# 本地開發
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Production (Render)
# NEXT_PUBLIC_API_BASE_URL=https://haude-api.onrender.com

# ------------------------------------------------------------------------------
# Development Options
# ------------------------------------------------------------------------------
# Mock 模式（開發用，設為 true 使用假資料登入）
# 開發環境建議 true，正式環境必須 false
NEXT_PUBLIC_USE_MOCK=false

# ------------------------------------------------------------------------------
# Supabase (可選 - 若前端直接使用 Supabase 功能)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ==============================================================================
# Production Checklist
# ==============================================================================
# [ ] NEXT_PUBLIC_API_BASE_URL 使用實際 API 網域（不含版本前綴）
# [ ] NEXT_PUBLIC_USE_MOCK=false
