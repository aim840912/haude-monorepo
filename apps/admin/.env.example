# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------
# 本地開發（API v1 版本）
VITE_API_URL=http://localhost:3001/api/v1

# Production (Render)
# VITE_API_URL=https://your-api.onrender.com/api/v1

# ==============================================================================
# Production Checklist
# ==============================================================================
# [ ] VITE_API_URL 使用實際 API 網域（含 /api/v1 前綴）
