# ==============================================================================
# Haude V2 API - Environment Variables
# ==============================================================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------------------------------------------
# 本地開發
# DATABASE_URL="postgresql://postgres:password@localhost:5432/haude_v2?schema=public"

# Supabase (Production)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ------------------------------------------------------------------------------
# Supabase Storage (for image uploads)
# ------------------------------------------------------------------------------
# Project URL: https://supabase.com/dashboard/project/[PROJECT-REF]/settings/api
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Service Role Key: https://supabase.com/dashboard/project/[PROJECT-REF]/settings/api-keys/legacy
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------------------
# 產生強密鑰: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------------------------------------------------
# CORS - Frontend URLs
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ------------------------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------------------------
# 在 Google Cloud Console 建立 OAuth 2.0 憑證
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ------------------------------------------------------------------------------
# Email Service (Resend)
# ------------------------------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@your-domain.com

# ------------------------------------------------------------------------------
# ECPay Payment Gateway (綠界金流)
# ------------------------------------------------------------------------------
ECPAY_MERCHANT_ID=your-merchant-id
ECPAY_HASH_KEY=your-hash-key
ECPAY_HASH_IV=your-hash-iv

# 測試環境: https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
# 正式環境: https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# ⚠️ 回調 URL 必須包含 /api/v1 前綴（NestJS global prefix）
ECPAY_NOTIFY_URL=https://your-api-domain/api/v1/payments/ecpay/notify
ECPAY_RETURN_URL=https://your-api-domain/api/v1/payments/ecpay/return
ECPAY_CLIENT_BACK_URL=https://your-frontend-domain/orders
ECPAY_PAYMENT_INFO_URL=https://your-api-domain/api/v1/payments/ecpay/info

# ECPay Test Credentials (開發測試用)
# ECPAY_MERCHANT_ID=2000132
# ECPAY_HASH_KEY=5294y06JbISpM5x9
# ECPAY_HASH_IV=v77hoKGq4kWxNNIS
# ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# ==============================================================================
# Production Checklist
# ==============================================================================
# [ ] DATABASE_URL 使用 Supabase Production 連線字串
# [ ] JWT_SECRET 使用強密鑰 (openssl rand -base64 64)
# [ ] NODE_ENV=production
# [ ] FRONTEND_URL 和 ADMIN_URL 使用實際網域
# [ ] GOOGLE_CALLBACK_URL 使用實際 API 網域
# [ ] RESEND_FROM_EMAIL 使用驗證過的網域
#
# ECPay 正式環境切換：
# [ ] ECPAY_MERCHANT_ID → 綠界提供的正式商店代號
# [ ] ECPAY_HASH_KEY → 綠界提供的正式 HashKey
# [ ] ECPAY_HASH_IV → 綠界提供的正式 HashIV
# [ ] ECPAY_API_URL → https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5（移除 -stage）
# [ ] ECPAY_NOTIFY_URL → https://haude-api.onrender.com/api/v1/payments/ecpay/notify
# [ ] ECPAY_RETURN_URL → https://haude-api.onrender.com/api/v1/payments/ecpay/return
# [ ] ECPAY_CLIENT_BACK_URL → https://haude-web.vercel.app/orders
# [ ] ECPAY_PAYMENT_INFO_URL → https://haude-api.onrender.com/api/v1/payments/ecpay/info
