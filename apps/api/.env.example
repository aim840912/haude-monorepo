# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/haude_v2?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase (if using Supabase as database)
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# NewebPay (Blue New Payment)
NEWEBPAY_MERCHANT_ID=your-merchant-id
NEWEBPAY_HASH_KEY=your-hash-key
NEWEBPAY_HASH_IV=your-hash-iv
