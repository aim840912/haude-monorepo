// Prisma Schema for Haude V2

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// User model
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // 可為空，Google 登入用戶不需要密碼
  name      String
  googleId  String?  @unique @map("google_id") // Google OAuth 用戶 ID
  avatar    String?  // Google 頭像 URL
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 帳號安全欄位
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")  // 連續登入失敗次數
  lockedUntil         DateTime? @map("locked_until")                       // 帳號鎖定到期時間

  // 會員等級欄位
  memberLevel    MemberLevel @default(NORMAL) @map("member_level")
  totalSpent     Int         @default(0) @map("total_spent")     // 累積消費（整數，單位：元）
  currentPoints  Int         @default(0) @map("current_points")  // 當前積分
  birthday       DateTime?   @db.Date                            // 生日（雙倍積分）
  levelUpdatedAt DateTime?   @map("level_updated_at")            // 等級更新時間

  // 關聯
  orders              Order[]
  farmTourBookings    FarmTourBooking[]
  cart                Cart?
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  discountUsages      DiscountUsage[]
  reviews             Review[]
  notifications       Notification[]
  pointTransactions   PointTransaction[]
  levelHistory        MemberLevelHistory[]
  operatedRefunds     Refund[]             @relation("refundOperator")

  @@index([memberLevel])
  @@map("users")
}

// Password Reset Token
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at") // 使用時間（null 表示未使用）
  createdAt DateTime @default(now()) @map("created_at")

  // 關聯
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// Refresh Token（httpOnly cookie 認證）
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // 關聯
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum Role {
  USER      // 一般會員：下單、報名活動
  VIP       // VIP 會員：專屬折扣、優先報名
  STAFF     // 員工：查看訂單、管理行程
  ADMIN     // 管理員：完整後台權限
}

// ========================================
// Member Level 模組（會員等級系統）
// ========================================

enum MemberLevel {
  NORMAL    // 普通會員
  BRONZE    // 銅卡會員
  SILVER    // 銀卡會員
  GOLD      // 金卡會員
}

enum PointTransactionType {
  PURCHASE      // 消費獲得
  BIRTHDAY      // 生日獎勵
  REDEMPTION    // 兌換扣除
  ADJUSTMENT    // 管理員調整
  EXPIRATION    // 過期扣除
}

// 積分交易紀錄
model PointTransaction {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  type        PointTransactionType
  points      Int                  // 正數=獲得，負數=扣除
  balance     Int                  // 交易後餘額
  description String?              // 交易描述
  orderId     String?              @map("order_id") // 關聯訂單
  expiresAt   DateTime?            @map("expires_at") // 過期時間
  createdAt   DateTime             @default(now()) @map("created_at")

  // 關聯
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
  @@map("point_transactions")
}

// 會員等級設定
model MemberLevelConfig {
  id              String      @id @default(uuid())
  level           MemberLevel @unique
  displayName     String      @map("display_name")      // 顯示名稱
  minSpent        Int         @map("min_spent")         // 最低累積消費（元）
  discountPercent Int         @map("discount_percent")  // 折扣百分比 (5 = 95折)
  freeShipping    Boolean     @default(false) @map("free_shipping")
  pointMultiplier Float       @default(1.0) @map("point_multiplier") // 積分倍率
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("member_level_configs")
}

// 會員等級變更歷史
model MemberLevelHistory {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  fromLevel   MemberLevel @map("from_level")
  toLevel     MemberLevel @map("to_level")
  reason      String      // 變更原因
  triggeredBy String?     @map("triggered_by") // 觸發者（system/admin）
  createdAt   DateTime    @default(now()) @map("created_at")

  // 關聯
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("member_level_history")
}

// ========================================
// Discounts 模組（折扣碼）
// ========================================

enum DiscountType {
  PERCENTAGE  // 百分比折扣
  FIXED       // 固定金額折扣
}

model DiscountCode {
  id             String       @id @default(uuid())
  code           String       @unique                        // 折扣碼（大寫）
  description    String?                                     // 描述
  discountType   DiscountType @map("discount_type")          // 折扣類型
  discountValue  Int          @map("discount_value")         // 折扣值（百分比或固定金額）
  minOrderAmount Int?         @map("min_order_amount")       // 最低訂單金額
  maxDiscount    Int?         @map("max_discount")           // 最高折扣金額（百分比折扣用）
  usageLimit     Int?         @map("usage_limit")            // 總使用次數限制
  usageCount     Int          @default(0) @map("usage_count") // 已使用次數
  perUserLimit   Int          @default(1) @map("per_user_limit") // 每人使用次數
  startDate      DateTime?    @map("start_date")             // 開始日期
  endDate        DateTime?    @map("end_date")               // 結束日期
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // 關聯
  usages DiscountUsage[]

  @@map("discount_codes")
}

model DiscountUsage {
  id             String   @id @default(uuid())
  discountCodeId String   @map("discount_code_id")
  userId         String   @map("user_id")
  orderId        String   @unique @map("order_id")  // 一個訂單只能使用一個折扣碼
  discountAmount Int      @map("discount_amount")   // 實際折扣金額
  createdAt      DateTime @default(now()) @map("created_at")

  // 關聯
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  order        Order        @relation(fields: [orderId], references: [id])

  @@index([discountCodeId])
  @@index([userId])
  @@map("discount_usages")
}

// ========================================
// Reviews 模組（產品評論）
// ========================================

model Review {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  userId     String   @map("user_id")
  rating     Int                              // 1-5 星評分
  title      String                           // 評論標題
  content    String   @db.Text                // 評論內容
  isVerified Boolean  @default(false) @map("is_verified") // 是否為已購買用戶
  isApproved Boolean  @default(true) @map("is_approved")  // 是否通過審核
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // 關聯
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 一個用戶對一個產品只能評論一次
  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// ========================================
// Products 模組
// ========================================

model Product {
  id            String    @id @default(uuid())
  name          String
  description   String    @db.Text
  category      String
  price         Int       // 價格（台幣整數）
  priceUnit     String?   @map("price_unit") // 價格單位（斤、包、箱等）
  unitQuantity  Int?      @map("unit_quantity") // 單位數量
  originalPrice Int?      @map("original_price") // 原價（促銷用）
  isOnSale      Boolean   @default(false) @map("is_on_sale") // 是否特價中
  saleEndDate   DateTime? @map("sale_end_date") // 特價結束日期
  stock         Int       @default(0) // 實際庫存
  reservedStock Int       @default(0) @map("reserved_stock") // 保留庫存
  isActive      Boolean   @default(true) @map("is_active") // 是否啟用
  isDraft       Boolean   @default(false) @map("is_draft") // 是否為草稿
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // 關聯
  images            ProductImage[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  reviews           Review[]
  stockAlertSetting StockAlertSetting?

  @@index([isActive, isDraft, createdAt(sort: Desc)])
  @@map("products")
}

model ProductImage {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  storageUrl      String   @map("storage_url") // 圖片 URL
  filePath        String   @map("file_path") // 儲存路徑
  altText         String?  @map("alt_text") // 替代文字
  displayPosition Int      @default(0) @map("display_position") // 排序位置
  size            String   @default("medium") // thumbnail, medium, large
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 關聯
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ========================================
// Cart 模組（購物車）
// ========================================

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id") // 一個用戶只有一個購物車
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 關聯
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 關聯
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 確保同一購物車內不會有重複的產品
  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ========================================
// Orders 模組
// ========================================

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  expired
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique @map("order_number") // 訂單編號
  userId          String        @map("user_id")
  status          OrderStatus   @default(pending) // 訂單狀態
  subtotal        Int           // 小計（台幣整數）
  shippingFee     Int           @map("shipping_fee") // 運費
  tax             Int           @default(0) // 稅費
  discountCode    String?       @map("discount_code") // 使用的折扣碼
  discountAmount  Int           @default(0) @map("discount_amount") // 折扣金額
  totalAmount     Int           @map("total_amount") // 總金額（扣除折扣後）
  shippingAddress Json          @map("shipping_address") // 配送地址
  paymentMethod   String?       @map("payment_method") // 付款方式
  paymentStatus   PaymentStatus @default(pending) @map("payment_status") // 付款狀態
  notes           String?       @db.Text // 訂單備註
  trackingNumber  String?       @map("tracking_number") // 物流追蹤號
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // 關聯
  user              User               @relation(fields: [userId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  refunds           Refund[]
  discountUsage     DiscountUsage?
  pointTransactions PointTransaction[]

  @@index([userId])
  @@index([status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  productId    String   @map("product_id")
  productName  String   @map("product_name") // 快照：下單時產品名稱
  productImage String?  @map("product_image") // 快照：下單時產品圖片
  quantity     Int // 購買數量
  unitPrice    Int      @map("unit_price") // 快照：下單時單價
  priceUnit    String?  @map("price_unit") // 價格單位
  subtotal     Int      // 小計
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 關聯
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ========================================
// Payments 模組
// ========================================

model Payment {
  id              String        @id @default(uuid())
  orderId         String        @map("order_id")
  merchantOrderNo String        @unique @map("merchant_order_no") // 商店訂單編號（給綠界用）
  tradeNo         String?       @map("trade_no") // 綠界交易編號
  status          PaymentStatus @default(pending)
  amount          Int // 金額（整數，單位：元）
  paymentType     String        @default("CREDIT") @map("payment_type") // CREDIT, ATM, CVS
  payTime         DateTime?     @map("pay_time") // 付款完成時間
  // ATM/CVS 專用欄位
  bankCode        String?       @map("bank_code") // ATM 銀行代碼
  vaAccount       String?       @map("va_account") // ATM 虛擬帳號
  paymentCode     String?       @map("payment_code") // CVS 繳費代碼
  expireDate      DateTime?     @map("expire_date") // 繳費期限
  // 原始資料
  requestData     Json?         @map("request_data") // 送出的請求參數
  responseData    Json?         @map("response_data") // 綠界回傳的資料
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // 關聯
  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  logs    PaymentLog[]
  refunds Refund[]

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model PaymentLog {
  id              String   @id @default(uuid())
  paymentId       String?  @map("payment_id")
  merchantOrderNo String   @map("merchant_order_no") // 商店訂單編號
  logType         String   @map("log_type") // notify, return, error
  rawData         Json     @map("raw_data") // 原始回調資料
  verified        Boolean  @default(false) // 簽章是否驗證通過
  processed       Boolean  @default(false) // 是否已處理
  ipAddress       String?  @map("ip_address") // 來源 IP
  createdAt       DateTime @default(now()) @map("created_at")

  // 關聯
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([merchantOrderNo])
  @@index([paymentId])
  @@map("payment_logs")
}

// ========================================
// Refunds 模組（退款管理）
// ========================================

enum RefundType {
  FULL    // 全額退款
  PARTIAL // 部分退款
}

enum RefundStatus {
  pending    // 待處理
  processing // 處理中（已送出 ECPay 請求或待人工處理）
  completed  // 已完成
  failed     // 失敗
}

model Refund {
  id            String       @id @default(uuid())
  paymentId     String       @map("payment_id")
  orderId       String       @map("order_id")
  operatorId    String       @map("operator_id") // 操作管理員
  type          RefundType // 全額/部分
  status        RefundStatus @default(pending)
  amount        Int // 退款金額（整數，單位：元）
  reason        String? // 退款原因
  ecpayResponse Json?        @map("ecpay_response") // ECPay 回應資料
  failReason    String?      @map("fail_reason") // 失敗原因
  completedAt   DateTime?    @map("completed_at") // 完成時間
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // 關聯
  payment  Payment @relation(fields: [paymentId], references: [id])
  order    Order   @relation(fields: [orderId], references: [id])
  operator User    @relation("refundOperator", fields: [operatorId], references: [id])

  @@index([paymentId])
  @@index([orderId])
  @@index([status])
  @@map("refunds")
}

// ========================================
// Farm Tours 模組（農場體驗）
// ========================================

enum FarmTourStatus {
  upcoming
  ongoing
  completed
  cancelled
}

enum FarmTourType {
  harvest   // 採摘體驗
  workshop  // 工作坊
  tour      // 導覽
  tasting   // 品嚐會
}

model FarmTour {
  id                  String         @id @default(uuid())
  name                String
  description         String         @db.Text
  date                DateTime       @db.Date
  startTime           String         @map("start_time") // e.g., "09:00"
  endTime             String         @map("end_time") // e.g., "12:00"
  price               Int            // 價格（台幣整數）
  maxParticipants     Int            @map("max_participants")
  currentParticipants Int            @default(0) @map("current_participants")
  location            String
  imageUrl            String?        @map("image_url")
  status              FarmTourStatus @default(upcoming)
  type                FarmTourType   @default(tour)
  tags                String[]       @default([])
  isActive            Boolean        @default(true) @map("is_active")
  isDraft             Boolean        @default(false) @map("is_draft")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // 關聯
  bookings FarmTourBooking[]
  images   FarmTourImage[]

  @@index([date])
  @@index([status])
  @@index([isActive, status, date])
  @@map("farm_tours")
}

model FarmTourImage {
  id              String   @id @default(uuid())
  farmTourId      String   @map("farm_tour_id")
  storageUrl      String   @map("storage_url")
  filePath        String   @map("file_path")
  altText         String?  @map("alt_text")
  displayPosition Int      @default(0) @map("display_position")
  size            String   @default("medium")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 關聯
  farmTour FarmTour @relation(fields: [farmTourId], references: [id], onDelete: Cascade)

  @@index([farmTourId])
  @@map("farm_tour_images")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model FarmTourBooking {
  id           String        @id @default(uuid())
  tourId       String        @map("tour_id")
  userId       String        @map("user_id")
  participants Int
  contactName  String        @map("contact_name")
  contactPhone String        @map("contact_phone")
  notes        String?       @db.Text
  status       BookingStatus @default(pending)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // 關聯
  tour FarmTour @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@index([tourId])
  @@index([userId])
  @@map("farm_tour_bookings")
}

// ========================================
// Locations 模組（據點管理）
// ========================================

model Location {
  id              String   @id @default(uuid())
  name            String
  title           String?
  address         String
  landmark        String?
  phone           String?
  lineId          String?  @map("line_id")
  hours           String?
  closedDays      String?  @map("closed_days")
  parking         String?
  publicTransport String?  @map("public_transport")
  features        String[] @default([])
  specialties     String[] @default([])
  lat             Decimal? @db.Decimal(10, 7)
  lng             Decimal? @db.Decimal(10, 7)
  image           String?
  isMain          Boolean  @default(false) @map("is_main")
  isActive        Boolean  @default(true) @map("is_active")
  isDraft         Boolean  @default(false) @map("is_draft")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 關聯
  images LocationImage[]

  @@map("locations")
}

model LocationImage {
  id              String   @id @default(uuid())
  locationId      String   @map("location_id")
  storageUrl      String   @map("storage_url")
  filePath        String   @map("file_path")
  altText         String?  @map("alt_text")
  displayPosition Int      @default(0) @map("display_position")
  size            String   @default("medium")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 關聯
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("location_images")
}

// ========================================
// Schedules 模組（市集日程）
// ========================================

enum ScheduleStatus {
  upcoming
  ongoing
  completed
  cancelled
}

model Schedule {
  id           String         @id @default(uuid())
  title        String
  location     String
  date         DateTime       @db.Date
  time         String // e.g., "06:00-12:00"
  status       ScheduleStatus @default(upcoming)
  products     String[]       @default([])
  description  String?        @db.Text
  contact      String?
  specialOffer String?        @map("special_offer")
  weatherNote  String?        @map("weather_note")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([date])
  @@index([status])
  @@index([isActive, date])
  @@map("schedules")
}

// ========================================
// Social Posts 模組（社群貼文嵌入）
// ========================================

enum SocialPlatform {
  facebook
  instagram
}

model SocialPost {
  id        String         @id @default(uuid())
  platform  SocialPlatform // facebook | instagram
  url       String         // 貼文 URL
  title     String?        // 選填標題/描述
  sortOrder Int            @default(0) @map("sort_order") // 排序順序
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([platform])
  @@index([isActive])
  @@map("social_posts")
}

// ========================================
// Notifications 模組（智慧通知系統）
// ========================================

enum NotificationType {
  LOW_STOCK        // 庫存預警
  NEW_ORDER        // 新訂單
  ORDER_CANCELLED  // 訂單取消
  PAYMENT_SUCCESS  // 付款成功
  PAYMENT_FAILED   // 付款失敗
  SYSTEM           // 系統通知
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?            // 額外資料（如訂單ID、產品ID等）
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  userId    String?          @map("user_id") // null 表示系統通知（所有管理員可見）
  createdAt DateTime         @default(now()) @map("created_at")

  // 關聯
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model StockAlertSetting {
  id        String   @id @default(uuid())
  productId String   @unique @map("product_id")
  threshold Int      @default(10) // 庫存低於此值時觸發警報
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 關聯
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_alert_settings")
}

// Site settings for CMS content management
model SiteSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("site_settings")
}
