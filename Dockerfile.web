# ==============================================================================
# Haude Web - Production Dockerfile (Next.js Standalone)
# ==============================================================================
# 使用方式：從根目錄建置
#   docker build -f Dockerfile.web -t haude-web .
#
# Vercel 設定（推薦）：
#   - 直接使用 Vercel 部署，無需 Dockerfile
#
# 其他雲端平台設定：
#   - Dockerfile Path: Dockerfile.web
#   - Docker Context Directory: . (根目錄)
# ==============================================================================

# ------------------------------------------------------------------------------
# Stage 1: Base - 安裝 pnpm
# ------------------------------------------------------------------------------
FROM node:20-alpine AS base

# 安裝 pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# 設定工作目錄
WORKDIR /app

# ------------------------------------------------------------------------------
# Stage 2: Dependencies - 安裝依賴
# ------------------------------------------------------------------------------
FROM base AS deps

# 複製 workspace 配置檔案
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# 複製各 package 的 package.json（保持目錄結構）
COPY apps/web/package.json ./apps/web/
COPY packages/types/package.json ./packages/types/

# 安裝所有依賴（包含 devDependencies，因為需要建置）
RUN pnpm install --frozen-lockfile

# ------------------------------------------------------------------------------
# Stage 3: Builder - 建置應用
# ------------------------------------------------------------------------------
FROM base AS builder

WORKDIR /app

# 複製依賴
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/types/node_modules ./packages/types/node_modules

# 複製原始碼
COPY . .

# 建置 types 套件（Web 依賴它，忽略錯誤以防萬一）
RUN pnpm --filter=@haude/types build || true

# 設定環境變數（建置時需要）
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# 建置 Next.js（會產生 standalone 輸出）
RUN pnpm --filter=@haude/web build

# ------------------------------------------------------------------------------
# Stage 4: Runner - 執行環境（最小化映像）
# ------------------------------------------------------------------------------
FROM node:20-alpine AS runner

WORKDIR /app

# 設定環境變數
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# 建立非 root 使用者（安全性）
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# 複製 public 資料夾（靜態資源）
COPY --from=builder /app/apps/web/public ./public

# 複製 Next.js standalone 輸出
# standalone 模式會在 .next/standalone 產生可獨立運行的 Node.js 應用
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# 切換到非 root 使用者
USER nextjs

# 暴露端口
EXPOSE 3000

# 健康檢查
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1

# 啟動應用（Next.js standalone 入口點）
CMD ["node", "apps/web/server.js"]
