# ==============================================================================
# Docker Ignore - Haude V2 Monorepo
# ==============================================================================

# ------------------------------------------------------------------------------
# Git
# ------------------------------------------------------------------------------
.git
.gitignore

# ------------------------------------------------------------------------------
# Dependencies (會在容器內重新安裝)
# ------------------------------------------------------------------------------
**/node_modules
**/.pnpm-store

# ------------------------------------------------------------------------------
# Build outputs (會在容器內重新建置)
# ------------------------------------------------------------------------------
**/dist
**/.next
**/build
**/.turbo

# ------------------------------------------------------------------------------
# Environment files (敏感資訊不應進入映像)
# ------------------------------------------------------------------------------
**/.env
**/.env.*
!**/.env.example

# ------------------------------------------------------------------------------
# IDE and editor
# ------------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo
.DS_Store

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
**/logs
**/*.log
npm-debug.log*
pnpm-debug.log*

# ------------------------------------------------------------------------------
# Test and coverage
# ------------------------------------------------------------------------------
**/coverage
**/.nyc_output

# ------------------------------------------------------------------------------
# Documentation and configs not needed in production
# ------------------------------------------------------------------------------
*.md
!README.md
CLAUDE.md
**/.claude
.playwright-mcp
docker-compose*.yml

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
.eslintcache
*.tgz
