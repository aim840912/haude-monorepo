{
  "name": "haude-v2",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@haude/web",
    "dev:admin": "turbo run dev --filter=@haude/admin",
    "dev:api": "turbo run dev --filter=@haude/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.7.3"
  }
}
