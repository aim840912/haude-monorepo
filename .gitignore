# ================================
# Dependencies
# ================================
node_modules/
.pnpm-store/
.pnpm-debug.log

# ================================
# Build outputs
# ================================
dist/
build/
.next/
out/

# ================================
# Turborepo
# ================================
.turbo/

# ================================
# Vite
# ================================
*.local
.vite/

# ================================
# Environment files
# ================================
.env
.env.local
.env.development
.env.development.local
.env.production
.env.test.local
.env.production.local
# Keep example files
!.env.example
!.env.*.example

# ================================
# Prisma
# ================================
# Generated Prisma Client (regenerated on install)
# prisma/generated/

# ================================
# IDE & Editors
# ================================
.idea/
*.swp
*.swo
*~

# VSCode - ignore user-specific settings, keep shared configs
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# ================================
# OS files
# ================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
*.stackdump
nul

# ================================
# Logs
# ================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ================================
# Testing
# ================================
coverage/
.nyc_output/

# ================================
# Playwright
# ================================
.playwright-mcp/
playwright-report/
test-results/

# ================================
# Cache & Temp files
# ================================
.cache/
*.tsbuildinfo
.eslintcache
.prettiercache

# ================================
# Screenshots & temp images (root level)
# ================================
/*.png
/*.jpg
/*.jpeg
/*.gif

# ================================
# Misc
# ================================
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Temporary folders
tmp/
temp/

# ================================
# Claude Code (auto-generated context files)
# ================================
# Ignore ALL CLAUDE.md files first
**/CLAUDE.md

# Then explicitly keep only these (manually maintained)
!/CLAUDE.md
!/.claude/CLAUDE.md
!/apps/*/CLAUDE.md

# Claude local data (never commit)
.claude-mem/
.claude/plugins/
.claude/settings.local.json

# ================================
# Local analysis & docs (not for git)
# ================================
PROJECT_ANALYSIS.md
docs/*
!docs/screenshots/
TESTpic/

# Screenshots (Playwright preview - local only)
/screenshots/
